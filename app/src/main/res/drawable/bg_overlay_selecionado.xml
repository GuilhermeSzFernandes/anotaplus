<?xml version="1.0" encoding="utf-8"?>
<!-- Mesmo raio de canto do bg_card_free — cobre o card quando selecionado
     no modo de seleção múltipla das Anotações, sem quadrar os cantos. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/brass_pill_bg" />
    <stroke
        android:width="1.5dp"
        android:color="@color/brass" />
    <corners android:radius="6dp" />
</shape>
