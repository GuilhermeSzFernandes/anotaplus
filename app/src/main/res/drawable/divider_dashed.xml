<?xml version="1.0" encoding="utf-8"?>
<!-- Substitui a PerforationView (Canvas customizado) nos lugares onde ela
     não pode ser usada, como no layout de um widget: RemoteViews só infla
     views nativas do Android, não classes customizadas do app. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="line">
    <stroke
        android:width="1dp"
        android:color="@color/ink_soft"
        android:dashWidth="4dp"
        android:dashGap="3dp" />
</shape>
