<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.AnotaPlus" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/ink</item>
        <item name="colorOnPrimary">@color/paper</item>
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!--
        Tema "modal": janela translúcida, sem título, sem animação de entrada/saída
        cheia de tela. É isso que dá a sensação de "apareceu um cartão por cima"
        em vez de "abriu um app".
    -->
    <style name="Theme.AnotaPlus.Modal" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/ink</item>
        <item name="colorOnPrimary">@color/paper</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@style/ModalAnimation</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/scrim</item>
    </style>

    <style name="ModalAnimation" parent="android:Animation">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <!-- Tipografia: wordmark pesado, corpo simples, tudo o que é dado/tempo em mono -->

    <style name="TextAppearance.AnotaPlus.Wordmark" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.AnotaPlus.Eyebrow" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/ink_soft</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.AnotaPlus.Amount" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">26sp</item>
    </style>

    <style name="TextAppearance.AnotaPlus.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.AnotaPlus.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/ink_soft</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Botões -->

    <style name="Widget.AnotaPlus.Button.Tab" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/tab_bg</item>
        <item name="android:textColor">@color/tab_text</item>
        <item name="strokeColor">@color/ink</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">3dp</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">@color/brass</item>
    </style>

    <style name="Widget.AnotaPlus.Button.Stamp" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/stamp_bg</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
        <item name="elevation">0dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
    </style>

    <style name="Widget.AnotaPlus.Button.Link" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/ink_soft</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">13sp</item>
        <item name="rippleColor">@color/brass</item>
    </style>

    <style name="Widget.AnotaPlus.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/paper</item>
        <item name="titleTextColor">@color/ink</item>
        <item name="titleTextAppearance">@style/TextAppearance.AnotaPlus.Wordmark</item>
    </style>

</resources>
