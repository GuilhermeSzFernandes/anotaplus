<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <EditText
            android:id="@+id/edit_nome_categoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_underline_field"
            android:hint="@string/hint_nome_categoria"
            android:inputType="text"
            android:textColor="@color/ink"
            android:textColorHint="@color/ink_soft"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/label_cor_categoria"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/container_cores"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/label_icone_categoria"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/container_icones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <EditText
            android:id="@+id/edit_limite_categoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_underline_field"
            android:hint="@string/hint_limite_categoria"
            android:inputType="numberDecimal"
            android:textColor="@color/ink"
            android:textColorHint="@color/ink_soft"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

    </LinearLayout>

</ScrollView>
