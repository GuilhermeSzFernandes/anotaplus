<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/paper"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="@color/ink">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:id="@+id/nav_anotacoes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:id="@+id/pill_anotacoes"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/icon_anotacoes"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_note"
                    android:contentDescription="@string/title_anotacoes" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_financeiro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:id="@+id/pill_financeiro"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/icon_financeiro"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_wallet"
                    android:contentDescription="@string/title_financeiro" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_inicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:id="@+id/pill_inicio"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/icon_inicio"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_home"
                    android:contentDescription="@string/title_inicio" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_relatorio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:id="@+id/pill_relatorio"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/icon_relatorio"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_report"
                    android:contentDescription="@string/title_relatorio" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_conta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:id="@+id/pill_conta"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/icon_conta"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_account"
                    android:contentDescription="@string/title_conta" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
