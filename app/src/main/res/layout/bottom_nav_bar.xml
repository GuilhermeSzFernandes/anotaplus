<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/ink"
    app:cardCornerRadius="28dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="10dp">

        <LinearLayout
            android:id="@+id/nav_inicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/icon_inicio"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                android:contentDescription="@string/title_inicio" />

            <TextView
                android:id="@+id/label_inicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/title_inicio"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Label"
                android:textColor="@color/paper" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_relatorio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/icon_relatorio"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_report"
                android:contentDescription="@string/title_relatorio" />

            <TextView
                android:id="@+id/label_relatorio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/title_relatorio"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Label"
                android:textColor="@color/paper" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_configuracoes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/icon_configuracoes"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_settings"
                android:contentDescription="@string/title_configuracoes" />

            <TextView
                android:id="@+id/label_configuracoes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/title_configuracoes"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Label"
                android:textColor="@color/paper" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
