<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_flat">

        <View
            android:id="@+id/view_stripe_cor"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            tools:background="@color/brass" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/text_titulo_nota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Ideia pro app novo" />

            <TextView
                android:id="@+id/text_preview_nota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
                android:textColor="@color/ink_soft"
                android:fontFamily="sans-serif"
                android:letterSpacing="0"
                android:maxLines="3"
                android:ellipsize="end"
                tools:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit." />

            <TextView
                android:id="@+id/text_tag_nota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
                android:textColor="@color/brass"
                android:visibility="gone"
                tools:text="trabalho"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/text_data_nota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:textColor="@color/ink_soft"
                android:textSize="10sp"
                tools:text="18 MAR" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/overlay_selecionado"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_overlay_selecionado"
        android:visibility="gone"
        tools:visibility="visible" />

</FrameLayout>
