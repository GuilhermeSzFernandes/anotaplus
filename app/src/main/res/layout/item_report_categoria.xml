<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/text_nome_categoria"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
            tools:text="Mercado" />

        <TextView
            android:id="@+id/text_valor_categoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.AnotaPlus.AmountBold"
            android:textColor="@color/color_gasto_vivo"
            android:textSize="15sp"
            tools:text="R$ 320,00" />

    </LinearLayout>

    <TextView
        android:id="@+id/text_delta_categoria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
        android:visibility="gone"
        tools:text="▲ 15% vs mês anterior"
        tools:visibility="visible" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="5dp"
        android:background="@color/paper_dim"
        android:orientation="horizontal">

        <View
            android:id="@+id/bar_fill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@color/gasto_color"
            android:layout_weight="50" />

        <View
            android:id="@+id/bar_track"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="50" />

    </LinearLayout>

</LinearLayout>
