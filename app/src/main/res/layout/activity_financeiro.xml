<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_financeiro"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Heading" />

        <ImageButton
            android:id="@+id/btn_categorias"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/title_categorias_carteiras"
            android:padding="9dp"
            android:src="@drawable/ic_tag"
            app:tint="@color/ink_soft" />

        <ImageButton
            android:id="@+id/btn_add_lancamento"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desc_adicionar_gasto"
            android:padding="8dp"
            android:src="@drawable/ic_add"
            app:tint="@color/brass" />

    </LinearLayout>

    <include
        android:id="@+id/row_mes"
        layout="@layout/row_month_selector"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/row_mes_divisor"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/paper_dim"
        app:layout_constraintTop_toBottomOf="@id/row_mes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/section_saldo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toBottomOf="@id/row_mes_divisor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Card-resumo: Receitas/Gastos lado a lado + Saldo embaixo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_flat"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_receitas"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

                    <TextView
                        android:id="@+id/text_total_receitas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.AmountBold"
                        android:textColor="@color/color_receita"
                        android:textSize="18sp"
                        tools:text="R$ 0,00" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/paper_dim" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_gastos"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

                    <TextView
                        android:id="@+id/text_total_gastos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.AmountBold"
                        android:textColor="@color/color_gasto_vivo"
                        android:textSize="18sp"
                        tools:text="R$ 0,00" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:background="@color/paper_dim" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/text_saldo_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/stat_saldo_estimado"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.RowTitle" />

                <TextView
                    android:id="@+id/text_saldo_valor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.AmountBold"
                    android:textSize="18sp"
                    tools:text="R$ 320,00"
                    tools:textColor="@color/color_receita" />

            </LinearLayout>

        </LinearLayout>

        <!-- Ações rápidas -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/label_acoes_rapidas"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btn_acao_gasto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:background="@drawable/bg_card_flat"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_arrow_expense"
                    app:tint="@color/color_gasto_vivo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/btn_acao_gasto"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.RowTitle" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_acao_ganho"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:background="@drawable/bg_card_flat"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_arrow_income"
                    app:tint="@color/color_receita" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/btn_acao_ganho"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.RowTitle" />

            </LinearLayout>

        </LinearLayout>

        <!-- Ticket "Saldo ao longo do mês" (gráfico da lib) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card_flat"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_saldo_periodo"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow" />

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chart_saldo"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="10dp" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_busca"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/section_saldo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_search"
            android:contentDescription="@string/content_desc_buscar" />

        <EditText
            android:id="@+id/edit_busca"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_underline_field"
            android:hint="@string/hint_buscar_lancamentos"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1"
            android:textColor="@color/ink"
            android:textColorHint="@color/ink_soft"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

    </LinearLayout>

    <TextView
        android:id="@+id/label_transacoes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:text="@string/label_transacoes"
        android:textAppearance="@style/TextAppearance.AnotaPlus.Label"
        app:layout_constraintTop_toBottomOf="@id/layout_busca"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_entries"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/label_transacoes"
        app:layout_constraintBottom_toTopOf="@id/ad_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Só visível pra quem não é PRO (ver FinanceiroActivity). Quando GONE,
         o RecyclerView (constrainedBottom_toTopOf este id) volta a ocupar
         o espaço inteiro sozinho, sem precisar de outra constraint.
         Container vazio em vez de declarar <AdView> aqui: o AdMob exige
         que adSize/adUnitId sejam setados "do mesmo jeito" (os dois via
         XML ou os dois via código) — declarar a tag aqui sem esses
         atributos conflitava com setar por código depois. O AdView em si
         é criado 100% programaticamente (ver FinanceiroActivity.kt). -->
    <FrameLayout
        android:id="@+id/ad_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include
        android:id="@+id/bottom_nav"
        layout="@layout/bottom_nav_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/btn_calculadora_nav"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginBottom="-22dp"
        android:background="@drawable/bg_fab_calculadora"
        android:elevation="6dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="@id/bottom_nav"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_calculator"
            app:tint="@color/paper"
            android:contentDescription="@string/titulo_calculadora_compra" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/recycler_entries"
        app:layout_constraintBottom_toBottomOf="@id/recycler_entries"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/text_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/empty_history"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
            android:textColor="@color/ink_soft" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_empty_add"
            style="@style/Widget.AnotaPlus.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/btn_empty_adicionar" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
