<?xml version="1.0" encoding="utf-8"?>
<!-- Mesmo padrão dos outros widgets: RemoteViews só infla views nativas,
     linhas fixas (6, ver CategoriasWidgetUpdater) em vez de uma coleção de
     verdade — mesma escolha de simplicidade/robustez já documentada em
     AnotacaoWidgetUpdater. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_categorias_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_paper">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/widget_categorias_titulo"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink"
                android:textSize="13sp"
                android:letterSpacing="0.06"
                android:textAllCaps="true" />

            <ImageButton
                android:id="@+id/btn_widget_categorias_add"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/desc_widget_add"
                android:padding="2dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_add" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:text=""
            android:background="@drawable/divider_dashed" />

        <TextView
            android:id="@+id/text_widget_categorias_vazio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/widget_categorias_vazio"
            android:textColor="@color/ink_soft"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/linha_cat_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_cat_0"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:gravity="center"
                android:textSize="13sp"
                tools:text="🛒" />

            <TextView
                android:id="@+id/nome_cat_0"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/ink"
                android:textSize="13sp"
                tools:text="Mercado" />

            <TextView
                android:id="@+id/valor_cat_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:textColor="@color/ink"
                android:textSize="13sp"
                tools:text="R$ 320,00" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linha_cat_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_cat_1"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:gravity="center"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/nome_cat_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/ink"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/valor_cat_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:textColor="@color/ink"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linha_cat_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_cat_2"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:gravity="center"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/nome_cat_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/ink"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/valor_cat_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:textColor="@color/ink"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linha_cat_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_cat_3"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:gravity="center"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/nome_cat_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/ink"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/valor_cat_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:textColor="@color/ink"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linha_cat_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_cat_4"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:gravity="center"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/nome_cat_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/ink"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/valor_cat_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:textColor="@color/ink"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linha_cat_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_cat_5"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:gravity="center"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/nome_cat_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/ink"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/valor_cat_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:textColor="@color/ink"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
