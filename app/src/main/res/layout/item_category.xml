<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/row_categoria_clicavel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:paddingVertical="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_nome_categoria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

            <TextView
                android:id="@+id/text_limite_categoria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
                android:textColor="@color/ink_soft"
                android:visibility="gone"
                tools:text="limite: R$ 500,00/mês"
                tools:visibility="visible" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_remover_categoria"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_remover_categoria"
            android:padding="8dp"
            android:src="@drawable/ic_delete" />

    </LinearLayout>

    <com.guilherme.anotaplus.ui.PerforationView
        android:layout_width="match_parent"
        android:layout_height="5dp"
        app:toothWidth="7dp"
        app:toothHeight="3dp"
        app:toothGap="3dp"
        app:toothColor="@color/paper_dim" />

</LinearLayout>
