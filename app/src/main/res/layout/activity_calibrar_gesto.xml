<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_calibrar_gesto"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Wordmark"
            android:textSize="20sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/calibrar_gesto_intro"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
            android:textColor="@color/ink_soft" />

        <com.guilherme.anotaplus.ui.PerforationView
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="20dp"
            app:toothWidth="8dp"
            app:toothHeight="4dp"
            app:toothGap="3dp"
            app:toothColor="@color/ink_soft" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/label_calibrar_leitura"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

        <TextView
            android:id="@+id/text_leitura_atual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Amount"
            tools:text="12.3 m/s²" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_leitura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:indicatorColor="@color/brass"
            app:trackColor="@color/paper_dim"
            app:trackThickness="8dp"
            app:trackCornerRadius="4dp" />

        <com.guilherme.anotaplus.ui.PerforationView
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="20dp"
            app:toothWidth="8dp"
            app:toothHeight="4dp"
            app:toothGap="3dp"
            app:toothColor="@color/ink_soft" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_calibrar_sensibilidade"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

            <TextView
                android:id="@+id/text_valor_limiar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Amount"
                android:textSize="18sp"
                tools:text="24" />

        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_limiar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:thumbColor="@color/brass"
            app:trackColorActive="@color/brass"
            app:trackColorInactive="@color/paper_dim" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/calibrar_dica_sensibilidade"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
            android:textColor="@color/ink_soft" />

        <com.guilherme.anotaplus.ui.PerforationView
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="20dp"
            app:toothWidth="8dp"
            app:toothHeight="4dp"
            app:toothGap="3dp"
            app:toothColor="@color/ink_soft" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/label_calibrar_teste"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

        <TextView
            android:id="@+id/text_status_teste"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/calibrar_teste_instrucao"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
            android:textColor="@color/ink_soft" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_calibrar_salvar"
            style="@style/Widget.AnotaPlus.Button.Stamp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/btn_calibrar_salvar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_calibrar_restaurar"
            style="@style/Widget.AnotaPlus.Button.Link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="@string/btn_calibrar_restaurar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_calibrar_concluir"
            style="@style/Widget.AnotaPlus.Button.Link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/btn_entendi" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
