<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_scrim"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/modal_scrim">

    <LinearLayout
        android:id="@+id/card_slip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:background="@drawable/bg_card_paper"
        android:elevation="6dp"
        android:clickable="true"
        android:focusable="true">

        <com.guilherme.anotaplus.ui.PerforationView
            android:layout_width="match_parent"
            android:layout_height="9dp"
            app:toothWidth="14dp"
            app:toothHeight="8dp"
            app:toothGap="5dp"
            app:toothColor="@color/scrim" />
        <!-- Único "dente" de recibo que sobrevive na tela toda — é o corte
             do topo do card, a própria identidade visual da Captura
             Rápida. Os outros divisores viraram linhas finas comuns. -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="18dp"
            android:paddingTop="14dp">

            <!-- Cabeçalho tipo recibo: marca + timestamp -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Wordmark" />

                <TextView
                    android:id="@+id/text_timestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
                    tools:text="20 JUL · 14:32" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:background="@color/paper_dim" />

            <!-- Toggle Anotações / Gasto / Recebimento -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_tipo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tipo_pensamento"
                    style="@style/Widget.AnotaPlus.Button.Tab"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_pensamento" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tipo_gasto"
                    style="@style/Widget.AnotaPlus.Button.Tab"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_gasto" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tipo_recebimento"
                    style="@style/Widget.AnotaPlus.Button.Tab"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_recebimento" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Valor: display tipo POS, só aparece quando "Gasto" está selecionado -->
            <LinearLayout
                android:id="@+id/layout_valor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_amount_field"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/prefix_valor"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Amount"
                    android:textColor="@color/ink_soft" />

                <EditText
                    android:id="@+id/edit_valor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:gravity="end"
                    android:hint="@string/hint_valor"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/ink_soft"
                    android:inputType="numberDecimal"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Amount" />

            </LinearLayout>

            <!-- Categoria (opcional), só pra Gasto. Combobox: sem teclado,
                 toque abre a lista completa das categorias salvas em
                 Configurações (não aceita texto livre). -->
            <AutoCompleteTextView
                android:id="@+id/edit_categoria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_underline_field"
                android:paddingHorizontal="4dp"
                android:paddingBottom="6dp"
                android:visibility="gone"
                android:hint="@string/hint_categoria"
                android:textColor="@color/ink"
                android:textColorHint="@color/ink_soft"
                android:inputType="none"
                android:cursorVisible="false"
                android:drawableEnd="@drawable/ic_chevron_down"
                android:drawablePadding="6dp"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
                tools:visibility="visible" />

            <!-- Carteira (opcional), pra Gasto/Recebimento. Mesmo padrão de categoria. -->
            <AutoCompleteTextView
                android:id="@+id/edit_carteira"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_underline_field"
                android:paddingHorizontal="4dp"
                android:paddingBottom="6dp"
                android:visibility="gone"
                android:hint="@string/hint_carteira"
                android:textColor="@color/ink"
                android:textColorHint="@color/ink_soft"
                android:inputType="none"
                android:cursorVisible="false"
                android:drawableEnd="@drawable/ic_chevron_down"
                android:drawablePadding="6dp"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
                tools:visibility="visible" />

            <!-- Campo de texto principal -->
            <EditText
                android:id="@+id/edit_texto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_underline_field"
                android:paddingHorizontal="4dp"
                android:paddingBottom="8dp"
                android:minLines="2"
                android:maxLines="5"
                android:gravity="top"
                android:hint="@string/hint_pensamento"
                android:textColor="@color/ink"
                android:textColorHint="@color/ink_soft"
                android:inputType="textMultiLine|textCapSentences"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
                android:lineSpacingExtra="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="@color/paper_dim" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_historico"
                    style="@style/Widget.AnotaPlus.Button.Link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="0dp"
                    android:text="@string/link_historico" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_salvar"
                    style="@style/Widget.AnotaPlus.Button.Stamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_salvar" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
