<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_vertical"
        android:minHeight="match_parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_guia_gesto"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Wordmark"
            android:textSize="20sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/guia_gesto_intro"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
            android:textColor="@color/ink_soft" />

        <com.guilherme.anotaplus.ui.PerforationView
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="20dp"
            app:toothWidth="8dp"
            app:toothHeight="4dp"
            app:toothGap="3dp"
            app:toothColor="@color/ink_soft" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/guia_gesto_passo_1"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/guia_gesto_passo_2"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/guia_gesto_passo_3"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/guia_gesto_passo_4"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

        </LinearLayout>

        <com.guilherme.anotaplus.ui.PerforationView
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="20dp"
            app:toothWidth="8dp"
            app:toothHeight="4dp"
            app:toothGap="3dp"
            app:toothColor="@color/ink_soft" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_abrir_config_moto"
            style="@style/Widget.AnotaPlus.Button.Stamp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/btn_abrir_config_moto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_entendi"
            style="@style/Widget.AnotaPlus.Button.Link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:text="@string/btn_entendi" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
