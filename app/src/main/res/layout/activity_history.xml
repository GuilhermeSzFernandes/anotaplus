<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.AnotaPlus.Toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:title="@string/btn_historico"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.guilherme.anotaplus.ui.PerforationView
        android:id="@+id/toolbar_perforation"
        android:layout_width="0dp"
        android:layout_height="6dp"
        app:toothWidth="8dp"
        app:toothHeight="4dp"
        app:toothGap="3dp"
        app:toothColor="@color/ink_soft"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_tipo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/paper"
        app:tabIndicatorColor="@color/brass"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="@color/ink"
        app:tabTextColor="@color/ink_soft"
        app:tabMode="fixed"
        app:layout_constraintTop_toBottomOf="@id/toolbar_perforation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_pensamento" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_gasto" />

    </com.google.android.material.tabs.TabLayout>

    <include
        android:id="@+id/row_mes"
        layout="@layout/row_month_selector"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        app:layout_constraintTop_toBottomOf="@id/tab_tipo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.guilherme.anotaplus.ui.PerforationView
        android:id="@+id/row_mes_perforation"
        android:layout_width="0dp"
        android:layout_height="5dp"
        app:toothWidth="7dp"
        app:toothHeight="3dp"
        app:toothGap="3dp"
        app:toothColor="@color/paper_dim"
        app:layout_constraintTop_toBottomOf="@id/row_mes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_entries"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/row_mes_perforation"
        app:layout_constraintBottom_toTopOf="@id/ad_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Só visível pra quem não é PRO (ver HistoryActivity). Quando GONE,
         o RecyclerView (constrainedBottom_toTopOf este id) volta a ocupar
         o espaço inteiro sozinho, sem precisar de outra constraint.
         Container vazio em vez de declarar <AdView> aqui: o AdMob exige
         que adSize/adUnitId sejam setados "do mesmo jeito" (os dois via
         XML ou os dois via código) — declarar a tag aqui sem esses
         atributos conflitava com setar por código depois. O AdView em si
         é criado 100% programaticamente (ver HistoryActivity.kt). -->
    <FrameLayout
        android:id="@+id/ad_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/text_empty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:text="@string/empty_history"
        android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
        android:textColor="@color/ink_soft"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/recycler_entries"
        app:layout_constraintBottom_toBottomOf="@id/recycler_entries"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
