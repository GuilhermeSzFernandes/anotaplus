<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_inicio"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Wordmark"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/text_mes_atual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/ink_soft"
            android:textSize="12sp"
            tools:text="JULHO 2026" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="100dp">

            <!-- Ticket "hero": saldo do mês, largura cheia -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_free"
                android:padding="18dp">

                <TextView
                    android:id="@+id/text_saldo_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
                    tools:text="Saldo estimado" />

                <TextView
                    android:id="@+id/text_saldo_valor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textSize="30sp"
                    tools:text="R$ 320,00"
                    tools:textColor="@color/color_positivo" />

            </LinearLayout>

            <!-- Rasgo entre os dois tickets — mesma ideia da Captura Rápida -->
            <com.guilherme.anotaplus.ui.PerforationView
                android:layout_width="match_parent"
                android:layout_height="6dp"
                app:toothWidth="8dp"
                app:toothHeight="4dp"
                app:toothGap="3dp"
                app:toothColor="@color/ink_soft" />

            <!-- Ticket "Últimos 7 dias": barras de gasto diário -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_free"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_ultimos_7_dias"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow" />

                <com.guilherme.anotaplus.ui.BarChartView
                    android:id="@+id/chart_semana"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginTop="12dp" />

                <LinearLayout
                    android:id="@+id/layout_dias_semana"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/text_dia_0" style="@style/TextDiaSemana" />
                    <TextView android:id="@+id/text_dia_1" style="@style/TextDiaSemana" />
                    <TextView android:id="@+id/text_dia_2" style="@style/TextDiaSemana" />
                    <TextView android:id="@+id/text_dia_3" style="@style/TextDiaSemana" />
                    <TextView android:id="@+id/text_dia_4" style="@style/TextDiaSemana" />
                    <TextView android:id="@+id/text_dia_5" style="@style/TextDiaSemana" />
                    <TextView android:id="@+id/text_dia_6" style="@style/TextDiaSemana" />

                </LinearLayout>

            </LinearLayout>

            <!-- Ticket "Últimos lançamentos" -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_free"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_ultimos_lancamentos"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow" />

                    <TextView
                        android:id="@+id/link_ver_tudo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/link_ver_tudo"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
                        android:textColor="@color/brass"
                        android:padding="4dp" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_recentes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/text_empty_recentes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/empty_history"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
                    android:textColor="@color/ink_soft"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        layout="@layout/bottom_nav_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
