<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_anotacoes"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Wordmark"
            android:textSize="20sp" />

        <ImageButton
            android:id="@+id/btn_add_ideia"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desc_adicionar_ideia"
            android:padding="8dp"
            android:src="@drawable/ic_add"
            app:tint="@color/brass" />

    </LinearLayout>

    <!-- Some no lugar do header normal enquanto tiver alguma nota
         selecionada (seleção múltipla via toque longo) -->
    <LinearLayout
        android:id="@+id/layout_selecao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_fechar_selecao"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_fechar_selecao"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            app:tint="@color/ink" />

        <TextView
            android:id="@+id/text_qtd_selecionadas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
            android:textStyle="bold"
            tools:text="3 selecionada(s)" />

        <ImageButton
            android:id="@+id/btn_tag_selecao"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_tag_selecao"
            android:padding="8dp"
            android:src="@drawable/ic_tag"
            app:tint="@color/brass" />

        <ImageButton
            android:id="@+id/btn_excluir_selecao"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_excluir_selecao"
            android:padding="8dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/gasto_color" />

    </LinearLayout>

    <!-- Header e layout_selecao nunca ficam visíveis juntos (ver
         AnotacoesActivity.atualizarBarraSelecao), mas cada um é ancorado
         independentemente ao topo — a barrier garante que o conteúdo
         abaixo siga o que estiver realmente visível, em vez de sempre
         colar embaixo do header quando ele vira GONE. -->
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="header,layout_selecao" />

    <com.guilherme.anotaplus.ui.PerforationView
        android:id="@+id/header_perforation"
        android:layout_width="0dp"
        android:layout_height="5dp"
        app:toothWidth="7dp"
        app:toothHeight="3dp"
        app:toothGap="3dp"
        app:toothColor="@color/paper_dim"
        app:layout_constraintTop_toBottomOf="@id/barrier_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layout_busca"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/header_perforation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_search"
            android:contentDescription="@string/content_desc_buscar" />

        <EditText
            android:id="@+id/edit_busca"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_underline_field"
            android:hint="@string/hint_buscar_anotacoes"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1"
            android:textColor="@color/ink"
            android:textColorHint="@color/ink_soft"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_entries"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layout_busca"
        app:layout_constraintBottom_toTopOf="@id/ad_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/ad_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include
        android:id="@+id/bottom_nav"
        layout="@layout/bottom_nav_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/recycler_entries"
        app:layout_constraintBottom_toBottomOf="@id/recycler_entries"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/text_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/empty_history"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
            android:textColor="@color/ink_soft" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_empty_add"
            style="@style/Widget.AnotaPlus.Button.Stamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/btn_empty_adicionar_anotacao" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
