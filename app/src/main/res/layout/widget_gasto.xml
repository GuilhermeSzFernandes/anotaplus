<?xml version="1.0" encoding="utf-8"?>
<!-- Layout do widget: RemoteViews só infla views nativas do Android (nada
     de PerforationView aqui), então o divisor tracejado vem de um drawable
     (@drawable/divider_dashed) em vez do Canvas customizado usado no resto
     do app. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_paper">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Atributos literais em vez de @style/TextAppearance.AnotaPlus.*:
                 essas styles herdam de TextAppearance.Material3.*, que
                 resolve atributos de tema (?attr/colorOnSurface etc.) — o
                 host do widget (launcher) infla com seu próprio tema, sem
                 o Theme.Material3 do app, e isso falha silenciosamente com
                 "Can't load widget". -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink"
                android:textSize="15sp"
                android:letterSpacing="0.08"
                android:textAllCaps="true" />

            <ImageButton
                android:id="@+id/btn_widget_add"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/desc_widget_add"
                android:padding="2dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_add" />

        </LinearLayout>

        <!-- TextView vazio em vez de View puro: RemoteViews só sabe inflar
             um conjunto fechado de classes (TextView, ImageView, etc.) —
             android.view.View "puro" não está nessa lista e quebra o
             widget assim que ele é colocado de verdade na tela (o preview
             na lista de widgets não passa por esse inflate real, só mostra
             o ícone do app, por isso parecia funcionar até esse ponto). -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:text=""
            android:background="@drawable/divider_dashed" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/widget_hoje"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/ink_soft"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/text_valor_hoje"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/ink"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="R$ 45,90" />

            </LinearLayout>

            <TextView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="12dp"
                android:text=""
                android:background="@color/ink_soft" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/widget_este_mes"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/ink_soft"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/text_valor_mes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/ink"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="R$ 1.234,56" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
