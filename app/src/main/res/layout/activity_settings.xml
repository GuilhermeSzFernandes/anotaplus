<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.AnotaPlus.Toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:title="@string/title_configuracoes"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.guilherme.anotaplus.ui.PerforationView
        android:layout_width="0dp"
        android:layout_height="6dp"
        app:toothWidth="8dp"
        app:toothHeight="4dp"
        app:toothGap="3dp"
        app:toothColor="@color/ink_soft"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/toolbar_perforation" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar_perforation"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_tipo_padrao"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_tipo_padrao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_padrao_gasto"
                    style="@style/Widget.AnotaPlus.Button.Tab"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_gasto" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_padrao_pensamento"
                    style="@style/Widget.AnotaPlus.Button.Tab"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_pensamento" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.guilherme.anotaplus.ui.PerforationView
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="24dp"
                app:toothWidth="8dp"
                app:toothHeight="4dp"
                app:toothGap="3dp"
                app:toothColor="@color/ink_soft" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_categorias"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/edit_nova_categoria"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_underline_field"
                    android:paddingHorizontal="4dp"
                    android:paddingBottom="6dp"
                    android:hint="@string/hint_nova_categoria"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/ink_soft"
                    android:inputType="text"
                    android:imeOptions="actionDone"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_categoria"
                    style="@style/Widget.AnotaPlus.Button.Stamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="+" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_categorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/text_empty_categorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/empty_categorias"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
                android:textColor="@color/ink_soft"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
