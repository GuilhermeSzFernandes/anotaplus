<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_conta"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Wordmark"
            android:textSize="20sp" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="100dp">

            <!-- CONTA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_free"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_conta"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

                <TextView
                    android:id="@+id/text_conta_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
                    android:textColor="@color/ink_soft"
                    tools:text="Faça login pra ativar o backup na nuvem (em breve)." />

                <LinearLayout
                    android:id="@+id/layout_conta_logada"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_conectado_como"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow" />

                    <TextView
                        android:id="@+id/text_conta_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/ink"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:ellipsize="middle"
                        tools:text="guilhermenovo3001@gmail.com" />

                    <!-- Backup em si: só aparece pra quem já é PRO -->
                    <LinearLayout
                        android:id="@+id/layout_backup_botoes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_fazer_backup"
                            style="@style/Widget.AnotaPlus.Button.Link"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="@string/btn_fazer_backup" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_restaurar_backup"
                            style="@style/Widget.AnotaPlus.Button.Link"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="@string/btn_restaurar_backup" />

                        <TextView
                            android:id="@+id/text_backup_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
                            android:visibility="gone"
                            tools:text="12 itens sincronizados"
                            tools:visibility="visible" />

                    </LinearLayout>

                    <!-- Quem tá logado mas não é PRO vê isso em vez dos botões -->
                    <LinearLayout
                        android:id="@+id/layout_backup_bloqueado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/backup_exclusivo_pro"
                            android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
                            android:textColor="@color/ink_soft" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_virar_pro"
                            style="@style/Widget.AnotaPlus.Button.Link"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="@string/link_virar_pro" />

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_entrar_google"
                    style="@style/Widget.AnotaPlus.Button.Stamp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/btn_entrar_google" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sair"
                    style="@style/Widget.AnotaPlus.Button.Link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"
                    android:text="@string/btn_sair" />

                <com.guilherme.anotaplus.ui.PerforationView
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="14dp"
                    app:toothWidth="7dp"
                    app:toothHeight="3dp"
                    app:toothGap="3dp"
                    app:toothColor="@color/paper_dim" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/link_ver_planos"
                    style="@style/Widget.AnotaPlus.Button.Link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/link_ver_planos" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/link_guia_gesto"
                    style="@style/Widget.AnotaPlus.Button.Link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/link_guia_gesto" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/link_ver_tutorial"
                    style="@style/Widget.AnotaPlus.Button.Link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/link_ver_tutorial" />

            </LinearLayout>

            <!-- TIPO PADRÃO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_free"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_tipo_padrao"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_tipo_padrao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_padrao_gasto"
                        style="@style/Widget.AnotaPlus.Button.Tab"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/btn_gasto" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_padrao_pensamento"
                        style="@style/Widget.AnotaPlus.Button.Tab"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/btn_toggle_pensamento" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_padrao_recebimento"
                        style="@style/Widget.AnotaPlus.Button.Tab"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/btn_toggle_recebimento" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

            </LinearLayout>

            <!-- NOTIFICAÇÃO DE CAPTURA RÁPIDA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_free"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_notificacao_captura"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_notificacao_captura"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/desc_notificacao_captura"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
                    android:textColor="@color/ink_soft" />

            </LinearLayout>

            <!-- GESTO DE TOQUE DUPLO (ACELERÔMETRO) — escondido em código
                 (SettingsActivity) se o aparelho não tiver acelerômetro. -->
            <LinearLayout
                android:id="@+id/card_gesto_acelerometro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_free"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_gesto_acelerometro"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_gesto_acelerometro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/desc_gesto_acelerometro"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
                    android:textColor="@color/ink_soft" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/link_calibrar_gesto"
                    style="@style/Widget.AnotaPlus.Button.Link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/link_calibrar_gesto" />

            </LinearLayout>

            <!-- Só existe em build debug (visibility trocada no código,
                 checando BuildConfig.DEBUG) — sem conta no Play Console
                 ainda, não tem como testar assinatura de verdade, então
                 esse switch força "sou PRO" localmente e no backend, sem
                 precisar comprar nada. -->
            <LinearLayout
                android:id="@+id/card_debug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_free"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_debug"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/switch_forcar_pro_debug"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_forcar_pro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        layout="@layout/bottom_nav_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
