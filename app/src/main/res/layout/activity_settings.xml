<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_conta"
            android:textAppearance="@style/TextAppearance.AnotaPlus.Heading" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="100dp">

            <!-- CONTA (login Google + backup na nuvem) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_flat"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_conta"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

                <TextView
                    android:id="@+id/text_conta_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
                    android:textColor="@color/ink_soft"
                    tools:text="Faça login pra ativar o backup na nuvem (em breve)." />

                <LinearLayout
                    android:id="@+id/layout_conta_logada"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_conectado_como"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow" />

                    <TextView
                        android:id="@+id/text_conta_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/ink"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:ellipsize="middle"
                        tools:text="guilhermenovo3001@gmail.com" />

                    <!-- Backup em si: só aparece pra quem já é PRO -->
                    <LinearLayout
                        android:id="@+id/layout_backup_botoes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_fazer_backup"
                            style="@style/Widget.AnotaPlus.Button.Link"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="@string/btn_fazer_backup" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_restaurar_backup"
                            style="@style/Widget.AnotaPlus.Button.Link"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="@string/btn_restaurar_backup" />

                        <TextView
                            android:id="@+id/text_backup_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="@style/TextAppearance.AnotaPlus.Eyebrow"
                            android:visibility="gone"
                            tools:text="12 itens sincronizados"
                            tools:visibility="visible" />

                    </LinearLayout>

                    <!-- Quem tá logado mas não é PRO vê isso em vez dos botões -->
                    <LinearLayout
                        android:id="@+id/layout_backup_bloqueado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/backup_exclusivo_pro"
                            android:textAppearance="@style/TextAppearance.AnotaPlus.Body"
                            android:textColor="@color/ink_soft" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_virar_pro"
                            style="@style/Widget.AnotaPlus.Button.Link"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            android:paddingHorizontal="0dp"
                            android:text="@string/link_virar_pro" />

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_entrar_google"
                    style="@style/Widget.AnotaPlus.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/btn_entrar_google" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sair"
                    style="@style/Widget.AnotaPlus.Button.Link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"
                    android:text="@string/btn_sair" />

            </LinearLayout>

            <!-- PROGRESSO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_progresso"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_flat"
                android:paddingHorizontal="12dp">

                <include
                    android:id="@+id/row_estatisticas"
                    layout="@layout/item_settings_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/paper_dim" />

                <include
                    android:id="@+id/row_historico"
                    layout="@layout/item_settings_row" />

            </LinearLayout>

            <!-- PERSONALIZAÇÃO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_personalizacao"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_flat"
                android:paddingHorizontal="12dp">

                <include
                    android:id="@+id/row_meu_plano"
                    layout="@layout/item_settings_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/paper_dim" />

                <include
                    android:id="@+id/row_tipo_padrao"
                    layout="@layout/item_settings_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/paper_dim" />

                <include
                    android:id="@+id/row_ajustar_objetivos"
                    layout="@layout/item_settings_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/paper_dim" />

                <include
                    android:id="@+id/row_notificacoes"
                    layout="@layout/item_settings_switch_row" />

            </LinearLayout>

            <!-- LEGAL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_legal"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_flat"
                android:paddingHorizontal="12dp">

                <include
                    android:id="@+id/row_privacidade"
                    layout="@layout/item_settings_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/paper_dim" />

                <include
                    android:id="@+id/row_termos"
                    layout="@layout/item_settings_row" />

            </LinearLayout>

            <!-- SUPORTE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_suporte"
                android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_flat"
                android:paddingHorizontal="12dp">

                <include
                    android:id="@+id/row_tutorial"
                    layout="@layout/item_settings_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/paper_dim" />

                <include
                    android:id="@+id/row_guia_gesto"
                    layout="@layout/item_settings_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/paper_dim" />

                <include
                    android:id="@+id/row_escolher_atalho"
                    layout="@layout/item_settings_row" />

            </LinearLayout>

            <!-- Só existe em build debug (visibility trocada no código,
                 checando BuildConfig.DEBUG) — sem conta no Play Console
                 ainda, não tem como testar assinatura de verdade, então
                 esse switch força "sou PRO" localmente e no backend, sem
                 precisar comprar nada. -->
            <LinearLayout
                android:id="@+id/card_debug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_flat"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_debug"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Label" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/switch_forcar_pro_debug"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_forcar_pro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        layout="@layout/bottom_nav_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
