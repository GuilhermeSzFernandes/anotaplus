<?xml version="1.0" encoding="utf-8"?>
<!-- Mostra uma ideia específica (escolhida em AnotacaoWidgetConfigActivity).
     Linhas fixas (não é um RemoteViewsService/coleção) — mais simples e
     robusto, ao custo de um limite de 6 linhas visíveis por widget,
     documentado no PROJETO.md. Cada linha pode ser texto simples ou um
     item de checklist (ImageView vira "☐"/"☑", tocável). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_anotacao_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_paper">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/text_anotacao_titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/ink"
            android:textSize="15sp"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Lista do mercado" />

        <LinearLayout
            android:id="@+id/linha_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/check_0"
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:textColor="@color/ink"
                android:textSize="15sp"
                tools:text="☐" />

            <TextView
                android:id="@+id/texto_0"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/ink"
                android:textSize="13sp"
                tools:text="Leite" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linha_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/check_1"
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:textColor="@color/ink"
                android:textSize="15sp"
                tools:text="☑" />

            <TextView
                android:id="@+id/texto_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/ink"
                android:textSize="13sp"
                tools:text="Pão" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linha_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/check_2"
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:textColor="@color/ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/texto_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/ink"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linha_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/check_3"
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:textColor="@color/ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/texto_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/ink"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linha_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/check_4"
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:textColor="@color/ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/texto_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/ink"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linha_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/check_5"
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:textColor="@color/ink"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/texto_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/ink"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
