<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.AnotaPlus.Toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:title="@string/title_planos"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.guilherme.anotaplus.ui.PerforationView
        android:layout_width="0dp"
        android:layout_height="6dp"
        app:toothWidth="8dp"
        app:toothHeight="4dp"
        app:toothGap="3dp"
        app:toothColor="@color/ink_soft"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/toolbar_perforation" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar_perforation"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- FREE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_free"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_plano_free"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Wordmark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textColor="@color/ink"
                        android:text="@string/preco_free" />

                </LinearLayout>

                <com.guilherme.anotaplus.ui.PerforationView
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="12dp"
                    app:toothWidth="7dp"
                    app:toothHeight="3dp"
                    app:toothGap="3dp"
                    app:toothColor="@color/paper_dim" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/feature_free_1"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/feature_free_2"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/feature_free_3"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/feature_free_4"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

            </LinearLayout>

            <!-- PREMIUM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_premium"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_plano_premium"
                        android:textAppearance="@style/TextAppearance.AnotaPlus.Wordmark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textColor="@color/ink"
                        android:text="@string/preco_premium" />

                </LinearLayout>

                <com.guilherme.anotaplus.ui.PerforationView
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="12dp"
                    app:toothWidth="7dp"
                    app:toothHeight="3dp"
                    app:toothGap="3dp"
                    app:toothColor="@color/brass" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/feature_premium_1"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/feature_premium_2"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/feature_premium_3"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/feature_premium_4"
                    android:textAppearance="@style/TextAppearance.AnotaPlus.Body" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_assinar"
                    style="@style/Widget.AnotaPlus.Button.Stamp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:enabled="false"
                    android:text="@string/btn_assinar_pro" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
