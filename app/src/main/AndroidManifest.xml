<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Login com Google + sync com o backend (Anota+ Cloud) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Notificação persistente de captura rápida (ver NotificationQuickAdd.kt)
         — obrigatória a partir do Android 13 (API 33), pedida em runtime
         quando o usuário liga o atalho em Conta. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".AnotaPlusApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.AnotaPlus">

        <!-- AdMob (anúncios do plano Free) — id obrigatório mesmo pros IDs
             de anúncio de teste usados agora (ver app/build.gradle.kts). -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="${adMobAppId}" />

        <!--
            Activity principal (única LAUNCHER do app): tanto o ícone quanto
            qualquer atalho que não venha de um toque na tela (ladrilho de
            Configurações Rápidas, widgets, atalhos de ícone) chegam aqui,
            já que todos disparam o mesmo intent MAIN/LAUNCHER. No onCreate,
            ela decide pra onde ir: se o intent tem sourceBounds (toque no
            ícone da tela inicial) abre o Início (ReportActivity); senão
            (tile/widget/atalho, que não vêm de um toque na tela) mostra o
            modal de captura.
            Tema translúcido para se comportar como um modal por cima da tela atual.
            noHistory + excludeFromRecents evitam que ela fique "presa" nos recentes
            e fazem a transição de volta ser instantânea ao fechar.
            IMPORTANTE: não usar launchMode="singleTask" aqui — já tentamos e
            quebrava a ilusão de modal: depois da primeira abertura, o Android
            passa a trazer a task antiga pra frente (troca de tela cheia) em
            vez de empilhar uma instância nova e translúcida por cima do app
            que estiver aberto no momento do gesto. launchMode padrão
            ("standard") é o certo aqui.
            taskAffinity="" (isolada, não compartilha task com as outras
            activities do app): sem isso, se o usuário já tivesse navegado
            pra Financeiro/Configurações/etc. e apenas pressionado Home (sem
            fechar), o atalho reaproveitava aquela task em segundo plano e o
            Android simplesmente trazia ela de volta (mostrando a última
            tela usada) — sem nem chegar a criar uma instância nova do
            QuickCaptureActivity, então o modal nunca aparecia. Com task
            própria, o atalho sempre cria uma instância nova e fresca,
            independente do que estiver rolando nas outras telas do app.
        -->
        <activity
            android:name=".QuickCaptureActivity"
            android:exported="true"
            android:theme="@style/Theme.AnotaPlus.Modal"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:windowSoftInputMode="adjustResize|stateVisible">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Atalhos de segurar o ícone (long-press) — outra forma de
                 captura rápida pra aparelho sem gesto de fabricante
                 configurável (ver res/xml/shortcuts.xml). -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <activity
            android:name=".AnotacoesActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".FinanceiroActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".ReportActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".CategoriasActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".ManualGastoActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ManualRecebimentoActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ManualIdeiaActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".EditEntryActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus"
            android:windowSoftInputMode="adjustResize" />

        <!--
            Sequência de onboarding (só aparece na primeiríssima abertura do
            app, controlado por Prefs.isOnboardingConcluido):
            QuickCaptureActivity -> LoginActivity -> NomeOnboardingActivity
            (como quer ser chamado) -> SalarioOnboardingActivity (dados
            salariais, só na criação da conta) -> MetaOnboardingActivity
            (primeira Meta, pulável) -> QuickAccessChooserActivity ->
            tutorial de cada método escolhido (GestureGuideActivity e/ou
            WidgetSuggestionActivity, encadeados por QuickAccessFlow.kt) ->
            AnotacoesActivity (com o tour de tutorial "spotlight" ativo, ver
            TutorialTourManager.kt).
            Cada uma também pode ser aberta isoladamente depois (fora do
            onboarding) a partir de Configurações — SalarioOnboardingActivity
            e MetaOnboardingActivity são exceção: não são reabertas fora do
            onboarding (dados salariais reabrem via dialog em
            SettingsActivity; novas Metas depois se criam por
            ReportActivity.abrirDialogNovaMeta).
        -->
        <activity
            android:name=".GestureGuideActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".NomeOnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".SalarioOnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".QuickAccessChooserActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".CalculadoraCompraActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".WidgetSuggestionActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".PlansActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <!-- Tela de configuração do widget "Uma Ideia" — aberta pelo
             próprio sistema (android:configure no widget_anotacao_info.xml)
             sempre que uma instância desse widget é adicionada. exported
             precisa ser true pro launcher/host do widget conseguir abrir. -->
        <activity
            android:name=".widget.AnotacaoWidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.AnotaPlus">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Ladrilho de Configurações Rápidas: abre a Captura Rápida em
             qualquer Android (puxar a barra + tocar), sem depender de
             gesto de fabricante — ver CapturaRapidaTileService.kt. -->
        <service
            android:name=".CapturaRapidaTileService"
            android:exported="true"
            android:icon="@drawable/ic_add"
            android:label="@string/tile_captura_rapida"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Widget de tela inicial: mostra o total gasto hoje e no mês,
             sem precisar abrir o app. Atualizado sob demanda (ver
             WidgetUpdater.kt) toda vez que um gasto é criado, editado,
             excluído ou restaurado do backup. -->
        <receiver
            android:name=".widget.GastoWidgetProvider"
            android:exported="false"
            android:label="@string/widget_nome">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_gasto_info" />
        </receiver>

        <!-- Segundo widget, bem menor: só um atalho pra Captura Rápida,
             pra quem não quer o widget de totais na tela inicial. -->
        <receiver
            android:name=".widget.CapturaRapidaWidgetProvider"
            android:exported="false"
            android:label="@string/widget_captura_rapida_nome">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_captura_rapida_info" />
        </receiver>

        <!-- Terceiro widget: mostra uma Ideia específica (escolhida na
             configuração), com checklist tocável direto da tela inicial. -->
        <receiver
            android:name=".widget.AnotacaoWidgetProvider"
            android:exported="false"
            android:label="@string/widget_anotacao_nome">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_anotacao_info" />
        </receiver>

        <receiver
            android:name=".widget.AnotacaoWidgetToggleReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.guilherme.anotaplus.TOGGLE_CHECKLIST_WIDGET" />
            </intent-filter>
        </receiver>

        <!-- Quarto widget: "espelho" visual do modal de Captura Rápida —
             nenhum campo funciona de verdade (RemoteViews não suporta
             EditText), tocar abre o modal de verdade pra digitar. -->
        <receiver
            android:name=".widget.CapturaModalWidgetProvider"
            android:exported="false"
            android:label="@string/widget_captura_modal_nome">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_captura_modal_info" />
        </receiver>

        <!-- Quinto widget: estreito e alto (1x2 células), dois alvos de
             toque empilhados (Gasto/Anotação), cada um já abre a Captura
             Rápida com o tipo certo. -->
        <receiver
            android:name=".widget.AdicionarWidgetProvider"
            android:exported="false"
            android:label="@string/widget_adicionar_nome">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_adicionar_info" />
        </receiver>

        <!-- Sexto widget: gasto do mês em cada categoria, maior pra menor
             (até 6 linhas) — ver CategoriasWidgetUpdater.kt. -->
        <receiver
            android:name=".widget.CategoriasWidgetProvider"
            android:exported="false"
            android:label="@string/widget_categorias_nome">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_categorias_info" />
        </receiver>

    </application>

</manifest>
