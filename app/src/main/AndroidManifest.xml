<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Login com Google + sync com o backend (Anota+ Cloud) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.AnotaPlus">

        <!--
            Activity principal (única LAUNCHER do app): tanto o ícone quanto o
            gesto "Toque duas vezes na traseira" do Moto Actions chegam aqui,
            já que os dois disparam o mesmo intent MAIN/LAUNCHER. No onCreate,
            ela decide pra onde ir: se o intent tem sourceBounds (toque no
            ícone da tela inicial) abre o Histórico; senão (gesto do Moto,
            que não vem de um toque na tela) mostra o modal de captura.
            Tema translúcido para se comportar como um modal por cima da tela atual.
            noHistory + excludeFromRecents evitam que ela fique "presa" nos recentes
            e fazem a transição de volta ser instantânea ao fechar.
        -->
        <activity
            android:name=".QuickCaptureActivity"
            android:exported="true"
            android:theme="@style/Theme.AnotaPlus.Modal"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize|stateVisible">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".ReportActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus" />

        <activity
            android:name=".ManualGastoActivity"
            android:exported="false"
            android:theme="@style/Theme.AnotaPlus"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>
